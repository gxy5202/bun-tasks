{
  "name": "bun-tasks",
  "version": "0.1.4",
  "description": "A lightweight parallel task runner for the Bun runtime inspired by concurrently",
  "type": "module",
  "bin": {
    "bun-tasks": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/bin.js",
      "types": "./dist/bin.d.ts"
    }
  },
  "main": "dist/bin.js",
  "types": "dist/bin.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "rimraf dist && bun build ./src/bin.ts --outdir=dist --target=bun --minify && tsc --emitDeclarationOnly -p tsconfig.json",
    "test": "bun test --coverage"
  },
  "keywords": [
    "bun",
    "parallel",
    "tasks",
    "runner"
  ],
  "author": "Gomi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gxy5202/bun-tasks"
  },
  "bugs": {
    "url": "https://github.com/gxy5202/bun-tasks/issues"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^20.12.12",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
